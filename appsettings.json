{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Key": "SuperSecretProductApiKey_2025_WithAtLeast32Chars!!",
    "Issuer": "ProductApi",
    "Audience": "ProductApi",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 7
  },
  "RateLimiting": {
    "WritePermitLimit": 1,
    "WriteWindowSeconds": 5,
    "AuthPermitLimit": 3,
    "AuthWindowSeconds": 60
  }
}
